{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Intelligent Rule Manager",
  "version": "0.1.0",
  "identifier": "io.learnwy.intelligent-rule-manager",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Intelligent Rule Manager",
        "width": 1400,
        "height": 920,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}

