{
  "name": "intelligent-rule-manager-vscode",
  "displayName": "Intelligent Rule Manager",
  "description": "VS Code-compatible extension for opening and operating the Intelligent Rule Manager workspace.",
  "version": "0.1.0",
  "publisher": "learnwy",
  "license": "MIT",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:intelligentRuleManager.openClientFolder",
    "onCommand:intelligentRuleManager.openClientSpec",
    "onCommand:intelligentRuleManager.runWorkspaceSummary",
    "onCommand:intelligentRuleManager.openRulesRoot"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "intelligentRuleManager.openClientFolder",
        "title": "Intelligent Rule Manager: Open Client Folder"
      },
      {
        "command": "intelligentRuleManager.openClientSpec",
        "title": "Intelligent Rule Manager: Open Client Spec"
      },
      {
        "command": "intelligentRuleManager.runWorkspaceSummary",
        "title": "Intelligent Rule Manager: Run Workspace Summary"
      },
      {
        "command": "intelligentRuleManager.openRulesRoot",
        "title": "Intelligent Rule Manager: Open Rules Root"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -w -p ./tsconfig.json",
    "vscode:prepublish": "pnpm compile"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@types/vscode": "^1.96.0",
    "typescript": "^5"
  }
}

