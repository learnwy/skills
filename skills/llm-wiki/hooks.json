    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.learnwy/skills/skills/llm-wiki/scripts/hooks/session-context.cjs",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
